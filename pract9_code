#include <stdio.h>
#include <stdlib.h>

void displayFrames(int *frames, int frameCount) {
    for(int i = 0; i < frameCount; i++) {
        if(frames[i] == -1)
            printf("- ");
        else
            printf("%d ", frames[i]);
    }
    printf("\n");
}

int isPagePresent(int *frames, int frameCount, int page) {
    for(int i = 0; i < frameCount; i++) {
        if(frames[i] == page)
            return 1;
    }
    return 0;
}

void fifoPageReplacement(int *pages, int pageCount, int frameCount) {
    int *frames = (int*)malloc(frameCount * sizeof(int));
    int pageFaults = 0;
    int pointer = 0;

    for(int i = 0; i < frameCount; i++)
        frames[i] = -1;

    printf("\nPage\tFrames\n");
    printf("-------------------\n");

    for(int i = 0; i < pageCount; i++) {
        printf("%d\t", pages[i]);

        if(!isPagePresent(frames, frameCount, pages[i])) {
            frames[pointer] = pages[i];
            pointer = (pointer + 1) % frameCount;
            pageFaults++;
        }

        displayFrames(frames, frameCount);
    }

    printf("\nTotal Page Faults: %d\n", pageFaults);
    printf("Page Fault Rate: %.2f\n", (float)pageFaults/pageCount);

    free(frames);
}

int main() {
    int pageCount, frameCount;

    printf("Enter number of pages: ");
    scanf("%d", &pageCount);

    int *pages = (int*)malloc(pageCount * sizeof(int));

    printf("Enter page reference string:\n");
    for(int i = 0; i < pageCount; i++) {
        scanf("%d", &pages[i]);
    }

    printf("Enter number of frames: ");
    scanf("%d", &frameCount);

    fifoPageReplacement(pages, pageCount, frameCount);

    free(pages);
    return 0;
}
